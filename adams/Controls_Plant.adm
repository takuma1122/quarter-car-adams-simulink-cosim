, YXFLAG = USER
, FUNCTION = USER(908, 2, 4)\
, ROUTINE = abgTire::gse908, abgTire::sti_gsexx908, abgTire::sti_gsexu908
, abgTire::sti_gseyx908, abgTire::sti_gseyu908
!
!----------------------------------- OUTPUT ------------------------------------
!
!                           adams_view_name='request'
REQUEST/5
, COMMENT = request
, CUNITS = "no_units", "acceleration", "length", "length"
, CNAMES = "", "sprung_acc", "susp_stroke", "unsprung_disp"
, RESULTS_NAME = request
, F2 = ACCZ(21)\
, F3 = DZ(21) - DZ(22) - SENVAL(1)\
, F4 = DZ(22) - SENVAL(2)
!
!                     adams_view_name='tire.radius_request'
REQUEST/6
, COMMENT = tire defl. - loaded and effective rolling radius - rot. velocity
, CUNITS = "no_units", "length", "length", "length", "no_units"
, "angular_velocity", "no_units", "no_units"
, CNAMES = "", "tire_deflection", "loaded_radius", "rolling_radius", ""
, "rotational_velocity", "", ""
, RESULTS_NAME = tire_rolling_states
, FUNCTION = USER(902, 23, 2)\
, ROUTINE = abgTire::req902
!
!                 adams_view_name='tire.kinematics_request_ISO'
REQUEST/7
, COMMENT = tire slip and inclination in ISO coordinate system
, CUNITS = "no_units", "no_units", "angle", "angle", "no_units", "no_units"
, "no_units", "no_units"
, CNAMES = "", "longitudinal_slip", "lateral_slip", "inclination_angle", "", ""
, "", ""
, RESULTS_NAME = tire_kinematics
, FUNCTION = USER(902, 2, 2)\
, ROUTINE = abgTire::req902
!
!                   adams_view_name='tire.forces_request_ISO'
REQUEST/8
, COMMENT = tire contact forces in ISO coordinate system
, CUNITS = "no_units", "force", "force", "force", "no_units", "torque", "torque"
, "torque"
, CNAMES = "", "longitudinal", "lateral", "normal", "", "overturning_moment"
, "rolling_resistance", "aligning_torque"
, RESULTS_NAME = tire_forces
, FUNCTION = USER(902, 3, 2)\
, ROUTINE = abgTire::req902
!
!                   adams_view_name='tire.hub_forces_request'
REQUEST/9
, COMMENT = forces on hub wrt to road reference marker
, CUNITS = "no_units", "force", "force", "force", "no_units", "torque", "torque"
, "torque"
, CNAMES = "", "longitudinal", "lateral", "normal", "", "overturning_moment"
, "rolling_resistance", "aligning_torque"
, RESULTS_NAME = tire_hub_forces
, FUNCTION = USER(902, 6, 2)\
, ROUTINE = abgTire::req902
!
!----------------------------- EXECUTION CONTROL -------------------------------
!
!                      adams_view_name='sen_init_susp_disp'
SENSOR/1
, VALUE = 0
, EQ
, FUNCTION = time\
, EVALUATE = DZ(21) - DZ(22)
!
!                    adams_view_name='sen_init_unsprung_disp'
SENSOR/2
, VALUE = 0
, EQ
, FUNCTION = time\
, EVALUATE = DZ(22)
!
!------------------------- GRAVITATIONAL ACCELERATION --------------------------
!
ACCGRAV/
, KGRAV = -9806.65
!
!----------------------------- ANALYSIS SETTINGS -------------------------------
!
OUTPUT/
, REQSAVE
!
RESULTS/
, XRF
!
END
