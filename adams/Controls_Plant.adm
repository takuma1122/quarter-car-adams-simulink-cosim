! Tire output array (forces and moments)
!                    adams_view_name='tire.tire_output_array'
ARRAY/2
, Y
!
! Tire states array
!                    adams_view_name='tire.tire_state_array'
ARRAY/3
, X
!
!Input array for tire gfosub
! p1 : id of ARRAY holding tire states
! p2 : number of tire states
! p3 : Side flag (0=left, 1=right)
! p4 : id of STRING statement holding role
! p5 : id of STRING statement holding tire property file name
! p6 : id of STRING statement holding simulation name
! p7 : id of STRING statement holding road property file name
! p8 : id of STRING statement holding contact type
! p9 : Tire radius for suspension analysis when a rigid wheel is used
! p10: id DIFF
! p11: ISWITCH (0=static tire, 1=dynamic tire)
! p12: id of ARRAY holding scaling and drift factors
! p13: id of ARRAY holding user parameters
! p14: id of jprim to lock wheel rotation (for steady state analysis)
! p15: RigK
! p16: initial speed
! p17: id of ARRAY holding doe parameters
! p18: id of wheel part
!                       adams_view_name='tire.input_array'
ARRAY/4
, IC
, SIZE = 18
, NUMBERS = 3, 2, 0, 3, 1, 5, 2, 4, 326, 0, 1, 5, 6, 0, 0, 0, 7, 6
!
!Scaling array for tire
! p1 : Unloaded Radius Offset
! p2 : Lateral Force Scale Factor
! p3 : Overturning Moment Scale Factor
! p4 : Aligning Torque Scale Factor
! p5 : Plysteer Force
! p6 : Conicity Force
! p7 : Plysteer Torque
! p8 : Conicity Torque
!                      adams_view_name='tire.scales_array'
ARRAY/5
, IC
, SIZE = 8
, NUMBERS = 0, 1, 1, 1, 0, 0, 0, 0
